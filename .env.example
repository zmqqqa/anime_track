# 数据库连接配置 (MySQL)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_database_user
MYSQL_PASSWORD=your_database_password
MYSQL_DATABASE=anime_track

# AI 配置
# 支持 DeepSeek / Qwen / GLM / OpenAI / OpenRouter / 豆包 / 其他兼容 OpenAI 格式的 API
#
# 字段说明:
# AI_API_KEY:      统一使用的 API Key（也兼容旧字段 DEEPSEEK_API_KEY）
# AI_API_URL:      必须填写完整聊天接口地址，通常以 /chat/completions 结尾
# AI_MODEL:        模型名或接入点 ID
# AI_JSON_FORMAT:  true 表示发送 response_format: json_object；false 表示关闭
# AI_DISABLE_THINKING:
#                  仅少数模型会用到。项目默认会自动对 Qwen / DashScope 关闭 thinking。
#                  如果你明确想开启，可手动设为 false。
#
# DeepSeek:
# AI_API_KEY=sk-xxxx
# AI_API_URL=https://api.deepseek.com/chat/completions
# AI_MODEL=deepseek-chat
# AI_JSON_FORMAT=true
#
# Qwen / 通义千问（阿里云 DashScope OpenAI 兼容模式）:
# AI_API_KEY=sk-xxxx
# AI_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# AI_MODEL=qwen3.5-flash
# AI_JSON_FORMAT=true
# AI_DISABLE_THINKING=true
# 特殊说明: 项目默认会给 Qwen 关闭 thinking；如果模型版本需要思考模式，再手动调整。
#
# GLM / 智谱:
# AI_API_KEY=your_glm_key
# AI_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
# AI_MODEL=glm-4-flash
# AI_JSON_FORMAT=true
#
# OpenAI 官方:
# AI_API_KEY=sk-proj-xxxx
# AI_API_URL=https://api.openai.com/v1/chat/completions
# AI_MODEL=gpt-4o-mini
# AI_JSON_FORMAT=true
#
# OpenRouter / 其他 OpenAI 兼容网关:
# AI_API_KEY=sk-or-xxxx
# AI_API_URL=https://openrouter.ai/api/v1/chat/completions
# AI_MODEL=openai/gpt-4o-mini
# AI_JSON_FORMAT=true
# 特殊说明: 只要兼容 chat/completions，这个项目一般都能接。
#
# 豆包 / 火山引擎 Ark:
# AI_API_KEY=your_volcengine_key
# AI_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
# AI_MODEL=ep-20260325xxxx-xxxxx
# AI_JSON_FORMAT=false
# 特殊说明:
# 1. AI_MODEL 往往不是 doubao-xxx 这种公开模型名，而是你在 Ark 控制台创建的 endpoint ID，例如 ep-xxxxx。
# 2. 不能只填 https://ark.cn-beijing.volces.com/api/v3，否则会直接 404。
# 3. 许多 Ark endpoint 不支持 response_format.type=json_object，所以通常要设为 false。

AI_API_KEY=your_api_key
AI_API_URL=https://api.deepseek.com/chat/completions
AI_MODEL=deepseek-chat
AI_JSON_FORMAT=true
# AI_DISABLE_THINKING=true

# NextAuth 配置 (身份验证)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_random_nextauth_secret

# 访客登录（可选）
GUEST_USERNAME=guest
GUEST_PASSWORD=guest

